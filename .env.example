# ============================================================================
# RC Gestor de Clientes — Variáveis de Ambiente (.env.example)
# Atualizado em: 2026-03 | Baseado em varredura exaustiva do código-fonte
# Total de variáveis mapeadas: 58 (código) → 40 documentadas aqui
# (variáveis de sistema como APPDATA/USERNAME e de teste como
#  RC_TESTING/PYTEST_CURRENT_TEST foram excluídas por design)
# ============================================================================

# ============================================================================
# 1. SUPABASE — CONEXÃO (OBRIGATÓRIAS para modo cloud)
# ============================================================================

SUPABASE_URL=
# Nota: SUPABASE_KEY e SUPABASE_ANON_KEY são equivalentes (use qualquer uma)
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# Organização padrão (fallback para "unknown-org" se vazio)
SUPABASE_DEFAULT_ORG=

# ============================================================================
# 2. SUPABASE — STORAGE
# ============================================================================

# Bucket padrão do Supabase Storage (default: rc-docs)
SUPABASE_BUCKET=rc-docs

# Bucket específico para uploads de clientes (default: clientes)
# SUPABASE_CLIENTS_BUCKET=clientes

# Bucket usado pelo módulo de storage de clientes (default: rc-docs)
# RC_STORAGE_BUCKET_CLIENTS=rc-docs

# Formato de pasta para clientes no storage (default: {org_id}/{client_id})
# RC_STORAGE_CLIENTS_FOLDER_FMT=

# ============================================================================
# 3. SUPABASE — AUTENTICAÇÃO BOOTSTRAP (dev/CI)
# ============================================================================

# Credenciais para bootstrap de autenticação (src/db/auth_bootstrap.py)
# SUPABASE_EMAIL=
# SUPABASE_PASSWORD=

# ============================================================================
# 4. SEGURANÇA / CRIPTOGRAFIA (OBRIGATÓRIA)
# ============================================================================

# Pepper para PBKDF2 — uma das duas é OBRIGATÓRIA (exceção se ambas vazias)
# Código: src/core/auth/auth.py:54
AUTH_PEPPER=
# RC_AUTH_PEPPER=

# ============================================================================
# 5. OPENAI / CHATGPT
# ============================================================================

# Chave da API OpenAI (obrigatória para usar o módulo ChatGPT)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo de chat (opcional — padrão: gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ============================================================================
# 6. CONFIGURAÇÃO DA APLICAÇÃO
# ============================================================================

# Nível de log (default: INFO)
RC_LOG_LEVEL=INFO

# Diretório de logs (default: artifacts/local/logs)
# RC_LOG_DIR=artifacts/local/logs

# Modo somente nuvem — sem filesystem local
# Em produção o bootstrap seta default "1" (cloud-only).
# Para desenvolvimento local com filesystem, use 0.
RC_NO_LOCAL_FS=0

# Diretório de dados da app (default: diretório raiz do projeto)
# RC_APP_DATA=

# Override de versão da app (default: valor de src/version.py)
# RC_APP_VERSION=

# Forçar sessão em arquivo em vez de registro (default: 0)
# RC_FORCE_FILE_SESSION=0

# Suprimir aviso de storage no startup (default: 1 = suprimido)
# RC_SUPPRESS_STORAGE_WARNING=1

# ============================================================================
# 7. HEALTH-CHECK E CONECTIVIDADE
# ============================================================================

# Intervalo entre verificações de conectividade em segundos (default: 30)
# RC_HEALTHCHECK_INTERVAL=30

# Threshold de instabilidade em segundos (default: 60)
# RC_HEALTHCHECK_UNSTABLE=60

# Desabilitar o health checker (1 = desligado, default: 0)
# RC_HEALTHCHECK_DISABLE=0

# Pular verificação de rede (1 = pular, default: 0)
# RC_NO_NET_CHECK=0

# Suprimir diálogos GUI de erro — útil em CI (1 = suprimir, default: 0)
# RC_NO_GUI_ERRORS=0

# ============================================================================
# 8. UPLOADS
# ============================================================================

# Tamanho máximo de upload em MB (default: 50)
# RC_UPLOAD_MAX_SIZE_MB=50

# Threshold de volume para pedir confirmação em MB (default: 200)
# RC_UPLOAD_CONFIRM_THRESHOLD=200

# Máximo de arquivos por lote — 0 = ilimitado (default: 0)
# RC_UPLOAD_MAX_FILES_PER_BATCH=0

# ============================================================================
# 9. MAPA DE AUTORES / UI
# ============================================================================

# JSON com mapeamento de emails para nomes curtos.
# Usado para exibir nomes amigáveis no Hub em vez de emails.
# Exemplo:
# RC_INITIALS_MAP={"usuario@dominio.com":"Nome","outro@dominio.com":"Outro Nome"}
RC_INITIALS_MAP=

# JSON com grupos de status personalizados para clientes
# RC_STATUS_GROUPS=

# ============================================================================
# 10. DEBUG E DIAGNÓSTICO (desabilitados por padrão)
# ============================================================================

# Rastreamento de after-jobs após shutdown (default: 0)
# RC_DEBUG_AFTER=0

# Debug de UI durante startup (default: 0)
# RC_DEBUG_STARTUP_UI=0

# Debug de exceções Tkinter (default: 0)
# RC_DEBUG_TK_EXCEPTIONS=0

# Modo strict para Tk root (default: 0)
# RC_STRICT_TK_ROOT=0

# Profiling de startup (default: 0)
# RC_PROFILE_STARTUP=0

# Modo verbose em UI (aceita: 1, true, yes, on) (default: false)
# RC_VERBOSE=0

# Desabilitar PyMuPDF — usa pypdf+OCR como fallback (default: 0)
# RC_DISABLE_PYMUPDF=0

# Reduzir iterações PBKDF2 em testes (valor numérico, sem default fixo)
# RC_PBKDF2_ITERS=
