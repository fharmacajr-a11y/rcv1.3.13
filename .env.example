# ============================================================================
# CONFIGURAÇÕES DO PROJETO
# ============================================================================

RC_LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=
# Nota: SUPABASE_KEY e SUPABASE_ANON_KEY são equivalentes (use qualquer uma)
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# Bucket padrão do Supabase Storage
SUPABASE_BUCKET=rc-docs

# Fallback para lista de buckets (quando list_buckets() não funciona por RLS)
# Use vírgula para separar múltiplos buckets
# Exemplo: RC_BUCKETS=rc-docs,rc-storage,outros-arquivos
RC_BUCKETS=rc-docs

# Organização padrão (fallback)
SUPABASE_DEFAULT_ORG=

# Modo somente nuvem (sem filesystem local)
RC_NO_LOCAL_FS=0

# ============================================================================
# CONFIGURAÇÕES DE HEALTH-CHECK E CONECTIVIDADE
# ============================================================================

# Intervalo entre verificações de conectividade (em segundos)
# RC_HEALTHCHECK_INTERVAL=30

# Threshold de instabilidade (em segundos)
# Após este tempo sem sucesso, conexão é considerada instável
# RC_HEALTHCHECK_UNSTABLE=60

# Desabilitar o health checker (útil para debug/instabilidade)
# Use 1 para desligar o checker
# RC_HEALTHCHECK_DISABLE=0

# Modo somente leitura (desabilita botões de escrita)
# RC_READONLY=0

# Desabilitar Supabase completamente (usa repositório local/offline se implementado)
# SUPABASE_DISABLED=0

# ============================================================================
# MAPA DE AUTORES (email → nome de exibição)
# ============================================================================

# JSON com mapeamento de emails para nomes curtos.
# Usado para exibir nomes amigáveis no Hub em vez de emails.
# Exemplo:
# RC_INITIALS_MAP={"usuario@dominio.com":"Nome","outro@dominio.com":"Outro Nome"}
RC_INITIALS_MAP=

# ============================================================================
# OPENAI / CHATGPT
# ============================================================================

# Chave da API OpenAI (obrigatória para usar o módulo ChatGPT)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo de chat (opcional — padrão: gpt-4o-mini)
# OPENAI_CHAT_MODEL=gpt-4o-mini
