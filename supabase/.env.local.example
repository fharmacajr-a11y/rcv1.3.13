# supabase/.env.local.example
# ---------------------------------------------------------------
# ESTE ARQUIVO É APENAS REFERÊNCIA DOCUMENTAL.
# O arquivo oficial usado pelo projeto é o .env na RAIZ do repo.
#
# Comando correto para servir a Edge Function:
#   .\supabase.exe functions serve zip-export --env-file .env
#
# NÃO crie supabase/.env.local — use o .env da raiz.
# ---------------------------------------------------------------
#
# Variáveis necessárias (definidas no .env da raiz):
#   SUPABASE_URL=https://<project-ref>.supabase.co
#   SUPABASE_ANON_KEY=<anon-key>
#   SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   (ou SUPABASE_SECRET_KEY)
#   ZIP_EXPORT_BUCKET=zip-exports
